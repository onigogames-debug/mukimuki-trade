{
  "name": "mukimuki-trade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preview": "python3 -m http.server 4173",
    "images:optimize": "node scripts/optimize-images.mjs",
    "critical:extract": "node scripts/extract-critical-css.mjs",
    "articles:generate": "node scripts/generate-articles.mjs",
    "performance:pages": "PERFORMANCE_OUTPUT_DIR=. node scripts/generate-performance-pages.mjs",
    "performance:pages:site": "PERFORMANCE_OUTPUT_DIR=_site node scripts/generate-performance-pages.mjs",
    "performance:latest-url": "node scripts/latest-performance-url.mjs",
    "performance:import": "node scripts/import-performance-report.mjs",
    "seo:generate": "node scripts/generate-seo.mjs",
    "sitemap:validate": "node scripts/validate-sitemap.mjs",
    "jsonld:identity": "node scripts/ensure-jsonld-identity.mjs",
    "links:canonical-performance": "node scripts/ensure-canonical-performance-links.mjs",
    "seo:audit": "node scripts/seo-audit.mjs",
    "cwv:apply": "node scripts/apply-cwv-optimizations.mjs",
    "build": "npm run images:optimize && npm run critical:extract && npm run articles:generate && npm run performance:pages && npm run seo:generate && npm run sitemap:validate && npm run jsonld:identity && npm run cwv:apply && npm run links:canonical-performance && npm run seo:audit",
    "deploy": "npx wrangler pages deploy . --project-name mukimuki-trade"
  },
  "devDependencies": {
    "postcss": "^8.5.6",
    "sharp": "^0.34.5"
  }
}
